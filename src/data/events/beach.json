            "effects": [{ "type": "recoverHp", "maxHpRatio": 0.12 }],
            "defaultTarget": { "type": "returnAdventure" },
            "resultIds": ["beach-ship-supplies"],
            "continueLabel": "離開廢船"
          }
        }
      ]
    },
