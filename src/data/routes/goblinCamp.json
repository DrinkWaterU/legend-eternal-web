  "eventDefinitions": [
    {
      "id": "goblin-looted-supplies",
      "weight": 100,
      "eyebrow": "哥布林營地事件",
      "title": "掠奪來的補給",
      "transitionText": [
        "你越過盾牌哨卡，繼續深入營地……",
        "破帆布之間，堆著一批凌亂物資。"
      ],
      "narrative": [
        "越過哨卡後，你在幾頂破帆布之間發現一批胡亂堆放的物資。",
        "乾糧、藥草、斷裂的武器與染血布條混在一起，其中不少東西明顯不屬於哥布林。",
        "你沒有太多時間。營地深處的動靜正逐漸靠近。"
      ],
      "prompt": "你打算怎麼利用這批補給？",
      "choices": [
        {
          "id": "eat-rations",
          "meta": "修復狀態",
          "title": "翻找能吃的東西",
          "description": "挑出尚未腐敗的乾糧與飲料，先讓身體重新有力氣。",
          "action": "恢復最大生命 35%",
          "result": {
            "narrative": [
              "你挑出尚未腐敗的乾糧與幾瓶氣味可疑的飲料。",
              "味道令人後悔，但至少身體重新有了力氣。"
            ],
            "effects": [
              {
                "type": "recoverHp",
                "maxHpRatio": 0.35
              }
            ],
            "resultIds": [
              "goblin-supplies-rested"
            ],
            "defaultTarget": {
              "type": "returnAdventure"
            },
            "continueLabel": "繼續深入營地",
            "followUpChoices": []
          }
        },
        {
          "id": "search-loot",
          "meta": "投資 Build",
          "title": "搜刮戰利品",
          "description": "放棄難以下嚥的補給，翻找武器與雜物中值得學會的手段。",
          "action": "額外進行 Goblin Blessing 三選一",
          "result": {
            "narrative": [
              "你放棄那些難以下嚥的東西，轉而翻找被哥布林隨手丟棄的武器與雜物。",
              "粗糙、卑劣，但其中確實藏著一些值得學會的手段。"
            ],
            "effects": [],
            "resultIds": [
              "goblin-supplies-looted"
            ],
            "defaultTarget": {
              "type": "chooseBlessing",
              "poolId": "goblin",
              "count": 3
            },
            "continueLabel": "挑選戰利品",
            "followUpChoices": []
          }
        }
      ]
    }
  ],
